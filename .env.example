WORTHLINE_DATA_DIR=.local/worthline

# Optional: a FREE CoinGecko "demo" API key (https://www.coingecko.com/en/api/pricing).
# Sent as the `x-cg-demo-api-key` header on every CoinGecko call, lifting the rate
# limit from the public tier (~5-15 req/min) to ~30 req/min. Without it, a Binance
# sync's live-price burst starves the history-range calls that follow (they 429),
# silently zeroing the reconstructed monthly history. Leave blank to use the public
# unauthenticated tier.
WORTHLINE_COINGECKO_API_KEY=

# Optional: Google OAuth credentials for Auth.js v5 sign-in. When all three are
# set, the app enters hosted mode: signed-out requests to real pages redirect to
# /login and signed-in users get their own provisioned workspace.
# Leave them blank to keep the local no-auth single-user mode.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=

# Hosted multi-tenant control plane (ADR 0030). Required when AUTH_GOOGLE_ID is
# set; ignored in local no-auth mode.
#
# - WORTHLINE_CONTROL_PLANE_DB_URL: the single libSQL database mapping users →
#   workspaces → grants.
# - WORTHLINE_DB_AUTH_TOKEN: the shared Turso group token used to open BOTH the
#   control plane and every per-workspace database.
# - TURSO_API_TOKEN / TURSO_ORG / TURSO_GROUP: Turso Platform API credentials used
#   to provision a fresh per-user workspace database on first login.
WORTHLINE_CONTROL_PLANE_DB_URL=
WORTHLINE_DB_AUTH_TOKEN=
TURSO_API_TOKEN=
TURSO_ORG=
TURSO_GROUP=

# Optional: open a single fixed remote libSQL workspace directly (local-against-
# remote dev, single-tenant). Ignored when the control plane above is configured.
WORTHLINE_DB_URL=

# Asistente financiero (#627/#704, ADR 0061). Cada entrada solo se activa con
# su credencial directa. El orden solo puede reordenar la allowlist validada.
GOOGLE_GENERATIVE_AI_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
WORTHLINE_CHAT_PROVIDER_ORDER=google,cerebras,groq
# Scope estable para cooldowns. Es obligatorio con control plane fuera de Vercel;
# Vercel usa VERCEL_URL (o VERCEL_ENV) por defecto.
WORTHLINE_CHAT_DEPLOYMENT_KEY=
