WORTHLINE_DATA_DIR=.local/worthline

# Optional: a FREE CoinGecko "demo" API key (https://www.coingecko.com/en/api/pricing).
# Sent as the `x-cg-demo-api-key` header on every CoinGecko call, lifting the rate
# limit from the public tier (~5-15 req/min) to ~30 req/min. Without it, a Binance
# sync's live-price burst starves the history-range calls that follow (they 429),
# silently zeroing the reconstructed monthly history. Leave blank to use the public
# unauthenticated tier.
WORTHLINE_COINGECKO_API_KEY=

# Optional: Google OAuth credentials for Auth.js v5 sign-in. When all three are
# set, the app enters hosted mode: signed-out requests to real pages redirect to
# /login and signed-in users open the workspace configured by WORTHLINE_DB_URL.
# Leave them blank to keep the local no-auth single-user mode.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=

# Optional: remote libSQL/Turso workspace used in hosted mode. Required when
# AUTH_GOOGLE_ID is set; ignored in local no-auth mode.
WORTHLINE_DB_URL=
WORTHLINE_DB_AUTH_TOKEN=
