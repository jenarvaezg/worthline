{
  "name": "worthline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @worthline/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint apps packages tests --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:first-run": "playwright test --config playwright.first-run.config.ts",
    "test:watch": "vitest",
    "backfill:snapshots": "tsx scripts/backfill-historical-snapshots.ts",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "drizzle-kit": "^0.31.10",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
