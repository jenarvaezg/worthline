{
  "name": "worthline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tests"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @worthline/web",
    "build": "turbo run build",
    "verify": "turbo run typecheck lint && npm run test && npm run format",
    "lint": "turbo run lint && eslint e2e scripts --max-warnings=0 --cache --cache-location node_modules/.cache/eslint-root",
    "test": "turbo run test --concurrency=1",
    "test:related": "vitest related --run",
    "test:e2e": "playwright test",
    "test:e2e:first-run": "npm run test:e2e:first-run:solo && npm run test:e2e:first-run:hogar",
    "test:e2e:first-run:solo": "FIRST_RUN_SCENARIO=solo playwright test --config playwright.first-run.config.ts",
    "test:e2e:first-run:hogar": "FIRST_RUN_SCENARIO=hogar playwright test --config playwright.first-run.config.ts",
    "test:e2e:demo": "npm run build --workspace @worthline/web && playwright test --config playwright.demo.config.ts",
    "test:watch": "vitest",
    "backfill:snapshots": "tsx scripts/backfill-historical-snapshots.ts",
    "sync:pull": "tsx scripts/sync-pull.ts",
    "sync:push": "tsx scripts/sync-push.ts",
    "subset:fonts": "scripts/subset-web-fonts.sh",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check . --cache --cache-location=node_modules/.cache/prettier/.prettier-cache",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "{apps,packages,tests,e2e,scripts}/**/*.{ts,tsx,js,jsx,mjs}": [
      "eslint --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx,mjs,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "latest",
    "drizzle-kit": "^0.31.10",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "latest",
    "tsx": "latest",
    "turbo": "^2.9.18",
    "typescript": "latest",
    "vitest": "latest"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true,
    "sharp": true,
    "unrs-resolver": true
  }
}
