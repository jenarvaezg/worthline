{
  "name": "@worthline/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@ai-sdk/cerebras": "^3.0.7",
    "@ai-sdk/google": "^4.0.12",
    "@ai-sdk/groq": "^4.0.5",
    "@ai-sdk/react": "^4.0.15",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@paddle/paddle-node-sdk": "^3.8.0",
    "@tursodatabase/api": "^2.0.4",
    "@worthline/db": "workspace:*",
    "@worthline/domain": "workspace:*",
    "@worthline/pricing": "workspace:*",
    "ai": "^7.0.14",
    "fflate": "^0.8.3",
    "jose": "^6.2.3",
    "mcp-handler": "^1.1.0",
    "next": "^16.0.0",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^4.0.2",
    "@auth/core": "^0.41.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "build": "bun ../../scripts/link-web-typescript-deps.ts && bun --bun next build && bun ../../scripts/emit-next-server-cjs-marker.ts",
    "dev": "bun --bun next dev --hostname 127.0.0.1",
    "eval:assistant": "tsx --env-file-if-exists=.env.local app/asistente/eval/run.ts",
    "eval:extractor": "tsx --env-file-if-exists=.env.local app/asistente/eval/extractor/run.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "start": "bun --bun next start --hostname 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
